<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
	<id>test_task_event_with_action</id>
	<version>1.0.0</version>
	<initials>TTE</initials>
	<title>Test task event with action</title>
	<icon>device_hub</icon>
	<defaultRole>true</defaultRole>
	<anonymousRole>true</anonymousRole>
	<transitionRole>false</transitionRole>
	<data type="text">
		<id>data1</id>
		<title/>
	</data>
	<transition>
		<id>t1</id>
		<x>368</x>
		<y>208</y>
		<label/>
		<event type="assign">
			<id>1_assign</id>
			<actions phase="post">
				<action>
					data1:f.data1;
					change data1 value { "test" }
				</action>
			</actions>
		</event>
		<event type="cancel">
			<id>1_cancel</id>
			<actions phase="post">
				<action>
					data1:f.data1;
					change data1 value { "test" }
				</action>
			</actions>
		</event>
		<event type="finish">
			<id>1_finish</id>
			<actions phase="post">
				<action>
					data1:f.data1;
					change data1 value { "test" }
				</action>
			</actions>
		</event>
		<event type="delegate">
			<id>1_delegate</id>
			<actions phase="post">
				<action>
					data1:f.data1;
					change data1 value { "test" }
				</action>
			</actions>
		</event>
	</transition>
	<place>
		<id>p1</id>
		<x>272</x>
		<y>208</y>
		<tokens>1</tokens>
		<static>false</static>
	</place>
	<place>
		<id>p2</id>
		<x>464</x>
		<y>208</y>
		<tokens>0</tokens>
		<static>false</static>
	</place>
	<arc>
		<id>a1</id>
		<type>regular</type>
		<sourceId>p1</sourceId>
		<destinationId>t1</destinationId>
		<multiplicity>1</multiplicity>
	</arc>
	<arc>
		<id>a2</id>
		<type>regular</type>
		<sourceId>t1</sourceId>
		<destinationId>p2</destinationId>
		<multiplicity>1</multiplicity>
	</arc>
</document>