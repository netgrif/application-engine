<document xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://petriflow.com/petriflow.schema.xsd">
	<id>workspace_async_test</id>
	<version>1.0.0</version>
	<initials>WAT</initials>
	<title>workspace_async_test</title>
	<icon>device_hub</icon>
	<defaultRole>true</defaultRole>
	<anonymousRole>false</anonymousRole>
	<transitionRole>false</transitionRole>
	<data type="text">
		<id>activeWorkspaceId</id>
		<title/>
	</data>
	<data type="text">
		<id>username</id>
		<title/>
	</data>
	<transition>
		<id>t1</id>
		<x>496</x>
		<y>112</y>
		<label/>
		<event type="finish">
			<id>t1_finish</id>
			<actions phase="post">
				<action id="1">
					<![CDATA[
					activeWorkspaceId: f.activeWorkspaceId,
					username: f.username;

					async.run {
					    com.netgrif.application.engine.concurrent.NaeThread.sleep(1000)
					    def loggedUser = userService.getLoggedUserFromContext()
					    setData("t2", useCase, ["username": ["value": loggedUser.username,"type": "text"],
					 			   "activeWorkspaceId": ["value": loggedUser.activeWorkspaceId,"type": "text"]])
					}
					]]>
				</action>
			</actions>
		</event>
	</transition>
	<transition>
		<id>t2</id>
		<x>464</x>
		<y>304</y>
		<label/>
	</transition>
	<place>
		<id>p1</id>
		<x>400</x>
		<y>112</y>
		<tokens>1</tokens>
		<static>false</static>
	</place>
	<place>
		<id>p2</id>
		<x>624</x>
		<y>112</y>
		<tokens>0</tokens>
		<static>false</static>
	</place>
	<arc>
		<id>a1</id>
		<type>regular</type>
		<sourceId>p1</sourceId>
		<destinationId>t1</destinationId>
		<multiplicity>1</multiplicity>
	</arc>
	<arc>
		<id>a2</id>
		<type>regular</type>
		<sourceId>t1</sourceId>
		<destinationId>p2</destinationId>
		<multiplicity>1</multiplicity>
	</arc>
</document>